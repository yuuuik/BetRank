export const getFeatured = () => services.filter(s => s.featured)
export const getPopular = () => services.filter(s => s.popular)
export const getBySlug = (slug: string) => services.find(s => s.slug === slug)
export const getCasinos = () => services.filter(s => s.type === 'casino' || s.type === 'both')
export const getBetting = () => services.filter(s => s.type === 'betting' || s.type === 'both')
